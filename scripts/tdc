#!/bin/bash
# tdc — TechDog Claude CLI wrapper
# Usage: tdc <command|file.md> [args]

set -e

TDC_VERSION="1.2.0"
TDC_HOME="${TDC_HOME:-$HOME/.tdc}"
TDC_PROJECT_DIR="$(pwd)"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

# Find tdc resource files (skills, agents)
# Priority: ~/.tdc/ → ~/.claude/ → ~/.tdc/.repo/.claude/ → error
find_tdc_source() {
    local resource_type="$1"  # "skills" or "agents"

    if [ -d "$TDC_HOME/$resource_type" ] && [ "$(ls -A "$TDC_HOME/$resource_type" 2>/dev/null)" ]; then
        echo "$TDC_HOME/$resource_type"
        return 0
    fi

    if [ -d "$HOME/.claude/$resource_type" ] && [ "$(ls -A "$HOME/.claude/$resource_type" 2>/dev/null)" ]; then
        echo "$HOME/.claude/$resource_type"
        return 0
    fi

    if [ -d "$TDC_HOME/.repo/.claude/$resource_type" ]; then
        echo "$TDC_HOME/.repo/.claude/$resource_type"
        return 0
    fi

    return 1
}

show_help() {
    cat << 'HELP'
TechDog Claude (tdc) v1.2.0
Multi-agent development orchestration for Claude Code

USAGE:
    tdc <file.md>             스펙 파일로 기획 → 개발 시작
    tdc <command> [arguments]  서브커맨드 실행

COMMANDS:
    <file.md>         스펙/플랜 파일을 읽고 자동 라우팅
    plan <file|desc>  기획 워크플로우
    dev  <file|desc>  개발 워크플로우
    debug <desc>      디버깅 워크플로우
    review [files]    코드 리뷰 워크플로우
    session <action>  세션 관리 (save|resume|list|clean)
    status            컨텍스트 & 세션 상태 확인
    init              프로젝트에 .tdc/ + .claude/ 초기화
    doctor            설치 상태 진단
    help              도움말

EXAMPLES:
    tdc init                      프로젝트 초기화
    tdc spec.md                   스펙 파일 기반 전체 워크플로우
    tdc plan my-api.md            기획만
    tdc dev                       최신 플랜으로 개발
    tdc debug "TypeError line 42" 버그 수정
    tdc review                    코드 리뷰
    tdc session resume            이전 세션 이어서
    tdc doctor                    설치 상태 확인
HELP
}

cmd_init() {
    echo -e "${BLUE}[tdc]${NC} Initializing project in $(pwd)..."

    # Create tdc state directory
    mkdir -p .tdc/{sessions,context,plans}

    # Create .claude directory for Claude Code
    mkdir -p .claude/{skills,agents}

    # Find source for skills and agents
    local skills_src agents_src
    local copied=false

    skills_src=$(find_tdc_source "skills") && {
        cp -r "$skills_src/"* .claude/skills/ 2>/dev/null || true
        copied=true
    }

    agents_src=$(find_tdc_source "agents") && {
        # Don't overwrite user's custom agents
        for f in "$agents_src/"*.md; do
            [ -f "$f" ] || continue
            local basename=$(basename "$f")
            if [ ! -f ".claude/agents/$basename" ]; then
                cp "$f" .claude/agents/
            fi
        done
        copied=true
    }

    if [ "$copied" = true ]; then
        echo -e "${GREEN}[tdc]${NC} .tdc/ and .claude/ initialized"
        echo -e "${GREEN}[tdc]${NC} Skills installed: $(find .claude/skills -name 'SKILL.md' 2>/dev/null | wc -l) files"
        echo -e "${GREEN}[tdc]${NC} Agents installed: $(ls .claude/agents/*.md 2>/dev/null | wc -l) files"
        echo ""
        echo -e "  ${BOLD}Next steps:${NC}"
        echo -e "    1. spec.md 파일을 만들어서 만들고 싶은 것을 적으세요"
        echo -e "    2. claude 실행 후 /tdc spec.md 입력"
    else
        echo -e "${YELLOW}[tdc]${NC} .tdc/ created but skills/agents source not found."
        echo -e "${YELLOW}[tdc]${NC} Run global install first:"
        echo "  curl -sSL https://raw.githubusercontent.com/dogyuHwang/techdog-claude/main/install.sh | bash"
    fi
}

cmd_doctor() {
    echo "=== TDC Doctor ==="
    echo ""

    # Check tdc CLI
    echo -n "tdc CLI:        "
    if command -v tdc &> /dev/null; then
        echo -e "${GREEN}OK${NC} ($(which tdc))"
    else
        echo -e "${RED}NOT FOUND${NC}"
    fi

    # Check TDC_HOME
    echo -n "TDC_HOME:       "
    if [ -d "$TDC_HOME" ]; then
        echo -e "${GREEN}OK${NC} ($TDC_HOME)"
    else
        echo -e "${RED}NOT FOUND${NC} ($TDC_HOME)"
    fi

    # Check global skills
    echo -n "Global skills:  "
    local global_skills=$(find "$HOME/.claude/skills" -name 'SKILL.md' -path '*/tdc*' 2>/dev/null | wc -l)
    if [ "$global_skills" -gt 0 ]; then
        echo -e "${GREEN}OK${NC} ($global_skills skills in ~/.claude/skills/)"
    else
        echo -e "${RED}NOT FOUND${NC} (run install.sh)"
    fi

    # Check global agents
    echo -n "Global agents:  "
    local global_agents=$(ls "$HOME/.claude/agents/master.md" 2>/dev/null | wc -l)
    if [ "$global_agents" -gt 0 ]; then
        echo -e "${GREEN}OK${NC} (in ~/.claude/agents/)"
    else
        echo -e "${RED}NOT FOUND${NC} (run install.sh)"
    fi

    # Check local project
    echo -n "Local .claude/:  "
    if [ -d ".claude/skills" ] && [ "$(find .claude/skills -name 'SKILL.md' -path '*/tdc*' 2>/dev/null | wc -l)" -gt 0 ]; then
        echo -e "${GREEN}OK${NC} ($(find .claude/skills -name 'SKILL.md' -path '*/tdc*' 2>/dev/null | wc -l) skills)"
    else
        echo -e "${YELLOW}NOT INIT${NC} (run 'tdc init' in this project)"
    fi

    # Check Claude Code
    echo -n "Claude Code:    "
    if command -v claude &> /dev/null; then
        echo -e "${GREEN}OK${NC} ($(claude --version 2>/dev/null))"
    else
        echo -e "${RED}NOT FOUND${NC}"
    fi

    # Check rtk
    echo -n "rtk:            "
    if command -v rtk &> /dev/null; then
        echo -e "${GREEN}OK${NC} ($(rtk --version 2>/dev/null))"
    else
        echo -e "${YELLOW}NOT INSTALLED${NC} (optional, for token savings)"
    fi

    # Check settings.json
    echo -n "settings.json:  "
    if [ -f "$HOME/.claude/settings.json" ]; then
        if python3 -c "import json; json.load(open('$HOME/.claude/settings.json'))" 2>/dev/null; then
            echo -e "${GREEN}OK${NC} (valid JSON)"
        else
            echo -e "${RED}INVALID JSON${NC}"
        fi
    else
        echo -e "${YELLOW}NOT FOUND${NC}"
    fi

    echo ""
}

cmd_status() {
    if [ -f "${TDC_HOME}/scripts/context-monitor.sh" ]; then
        bash "${TDC_HOME}/scripts/context-monitor.sh" "$TDC_PROJECT_DIR"
    else
        echo -e "${YELLOW}[tdc]${NC} context-monitor.sh not found. Run install.sh first."
    fi
}

cmd_session() {
    local action="${1:-list}"
    local session_dir=".tdc/sessions"

    case "$action" in
        list)
            if [ ! -d "$session_dir" ] || [ -z "$(ls -A "$session_dir" 2>/dev/null)" ]; then
                echo -e "${YELLOW}[tdc]${NC} No saved sessions."
                return
            fi
            echo "=== Saved Sessions ==="
            for f in "$session_dir"/*.json; do
                [ -f "$f" ] || continue
                local id=$(basename "$f" .json)
                local task=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get('task','(auto-save)'))" "$f" 2>/dev/null || echo "unknown")
                echo "  $id — $task"
            done
            ;;
        save)
            echo -e "${BLUE}[tdc]${NC} Use /tdc-session save inside Claude Code for full context preservation."
            ;;
        resume)
            local target="$2"
            if [ -z "$target" ]; then
                target=$(ls -t "$session_dir"/*.json 2>/dev/null | head -1)
            else
                target="$session_dir/${target}.json"
            fi
            if [ -f "$target" ]; then
                echo -e "${GREEN}[tdc]${NC} Resuming session: $(basename "$target" .json)"
                cat "$target"
            else
                echo -e "${RED}[tdc]${NC} No session found to resume."
            fi
            ;;
        clean)
            find "$session_dir" -name "*.json" -mtime +7 -delete 2>/dev/null
            echo -e "${GREEN}[tdc]${NC} Cleaned sessions older than 7 days."
            ;;
        *)
            echo -e "${RED}[tdc]${NC} Unknown session action: $action"
            ;;
    esac
}

cmd_claude() {
    local skill="$1"
    shift
    local args="$*"

    if command -v claude &> /dev/null; then
        echo -e "${BLUE}[tdc]${NC} Launching Claude Code with /${skill} ${args}..."
        claude -p "/$skill $args"
    else
        echo -e "${RED}[tdc]${NC} Claude Code CLI not found. Install:"
        echo "  npm install -g @anthropic-ai/claude-code"
        exit 1
    fi
}

is_file_arg() {
    [[ "$1" == *.md ]] || [[ -f "$1" ]]
}

# Main routing
INPUT="${1:-help}"

case "$INPUT" in
    plan)    shift; cmd_claude "tdc-plan" "$@" ;;
    dev)     shift; cmd_claude "tdc-dev" "$@" ;;
    debug)   shift; cmd_claude "tdc-debug" "$@" ;;
    review)  shift; cmd_claude "tdc-review" "$@" ;;
    session) shift; cmd_session "$@" ;;
    status)  cmd_status ;;
    init)    cmd_init ;;
    doctor)  cmd_doctor ;;
    help|-h|--help) show_help ;;
    version|-v|--version) echo "tdc v${TDC_VERSION}" ;;
    *)
        if is_file_arg "$INPUT"; then
            if [ ! -f "$INPUT" ]; then
                echo -e "${RED}[tdc]${NC} File not found: $INPUT"
                exit 1
            fi
            echo -e "${BLUE}[tdc]${NC} Reading spec: $INPUT"
            cmd_claude "tdc" "$INPUT"
        else
            shift; cmd_claude "tdc" "$@"
        fi
        ;;
esac
