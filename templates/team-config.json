{
  "team": {
    "name": "techdog-claude",
    "version": "1.1.0",
    "agents": {
      "master": {
        "role": "orchestrator",
        "model": "opus",
        "description": "Team leader — delegates, synthesizes, manages context",
        "max_concurrent_delegates": 3
      },
      "planner": {
        "role": "planner",
        "model": "sonnet",
        "description": "Requirement analysis, task breakdown, TDD gate planning",
        "token_budget": 4000
      },
      "developer": {
        "role": "executor",
        "model": "sonnet",
        "description": "Code implementation — follows TDD RED→GREEN→REFACTOR",
        "token_budget": 8000
      },
      "debugger": {
        "role": "executor",
        "model": "sonnet",
        "description": "Bug diagnosis and root cause analysis",
        "token_budget": 6000
      },
      "reviewer": {
        "role": "reviewer",
        "model": "haiku",
        "description": "2-stage review: Stage 1 Spec Compliance, Stage 2 Code Quality",
        "token_budget": 3000
      },
      "security-reviewer": {
        "role": "reviewer",
        "model": "haiku",
        "description": "OWASP top 10 security review",
        "token_budget": 2000
      },
      "test-engineer": {
        "role": "executor",
        "model": "sonnet",
        "description": "Test coverage analysis and test generation",
        "token_budget": 5000
      },
      "meta-reviewer": {
        "role": "reviewer",
        "model": "haiku",
        "description": "tdc internal consistency audit — auto-triggered when tdc files are modified",
        "token_budget": 2000,
        "trigger": {
          "auto": true,
          "condition": "git diff --name-only matches agents/|skills/|hooks/|templates/|CLAUDE.md|MAINTENANCE.md",
          "parallel_with": "reviewer"
        },
        "checks": [
          "context_file_cleanup_sync",
          "agent_file_config_completeness",
          "token_budget_consistency",
          "claude_md_command_skill_existence",
          "inter_agent_reference_validity",
          "deep_mode_cleanup_completeness"
        ]
      },
      "architect": {
        "role": "advisor",
        "model": "opus",
        "description": "System design, architecture decisions, Extended Thinking enabled",
        "token_budget": 6000,
        "extended_thinking": {
          "enabled": true,
          "budget_tokens": 8000,
          "use_when": ["oscillation_detected", "critical_design_decision", "migration_planning"]
        }
      }
    },
    "model_tiers": {
      "haiku": {
        "use_for": ["review", "simple_queries", "style_checks"],
        "cost_per_1k_input": 0.0008,
        "cost_per_1k_output": 0.004
      },
      "sonnet": {
        "use_for": ["implementation", "debugging", "planning", "standard_tasks"],
        "cost_per_1k_input": 0.003,
        "cost_per_1k_output": 0.015
      },
      "opus": {
        "use_for": ["architecture", "complex_reasoning", "orchestration"],
        "cost_per_1k_input": 0.015,
        "cost_per_1k_output": 0.075
      }
    },
    "prompt_caching": {
      "enabled": true,
      "strategy": "Mark system prompts >2048 tokens with cache_control ephemeral",
      "eligible_agents": ["master", "developer", "planner"],
      "expected_savings": "60-90% on repeated invocations within 5-min TTL",
      "note": "Cache agent system prompts when same agent is called multiple times in regression loop"
    },
    "token_optimization": {
      "max_context_tool_calls": 120,
      "warn_at_tool_calls": 80,
      "auto_save_on_overflow": true,
      "compress_intermediate_results": true,
      "lazy_load_agent_context": true
    },
    "oscillation_detection": {
      "enabled": true,
      "regression_history_file": ".tdc/context/.regression-history",
      "trigger_on_repeated_issues": 2,
      "escalation": "architect"
    },
    "tdd_gates": {
      "enabled": true,
      "require_test_first_steps_for_complex_tasks": true,
      "complexity_threshold": "mid",
      "fail_fast_on_red_stage_skip": true
    }
  }
}
