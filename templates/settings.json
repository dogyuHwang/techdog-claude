{
  "env": {
    "TDC_HOME": "$HOME/.tdc",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.tdc/hooks/tdc-status.sh",
    "padding": 2
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.tdc/hooks/context-guard.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.tdc/hooks/smart-read.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.tdc/hooks/agent-tracker.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.tdc/hooks/agent-tracker.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.tdc/hooks/session-save.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(mkdir -p .tdc/*)",
      "Read(.tdc/**)",
      "Write(.tdc/sessions/**)",
      "Write(.tdc/context/**)",
      "Write(.tdc/plans/**)",
      "Bash(bash $HOME/.tdc/hooks/context-guard.sh)",
      "Bash(bash $HOME/.tdc/hooks/session-save.sh)",
      "Bash(bash $HOME/.tdc/hooks/agent-tracker.sh)",
      "Bash(bash $HOME/.tdc/hooks/tdc-status.sh)",
      "Bash(bash $HOME/.tdc/hooks/smart-read.sh)"
    ]
  }
}
