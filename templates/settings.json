{
  "env": {
    "TDC_HOME": "$HOME/.tdc",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.tdc/hooks/context-guard.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.tdc/hooks/session-save.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(mkdir -p .tdc/*)",
      "Read(.tdc/**)",
      "Write(.tdc/sessions/**)",
      "Write(.tdc/context/**)",
      "Write(.tdc/plans/**)",
      "Bash(bash $HOME/.tdc/hooks/context-guard.sh)",
      "Bash(bash $HOME/.tdc/hooks/session-save.sh)"
    ]
  }
}
