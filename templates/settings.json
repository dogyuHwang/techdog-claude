{
  "env": {
    "TDC_HOME": "$HOME/.tdc",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "postToolExecution": [
      {
        "type": "command",
        "command": "bash $HOME/.tdc/hooks/context-guard.sh",
        "description": "TDC context monitor — tracks tool call count for session management"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(mkdir -p .tdc/*)",
      "Read(.tdc/**)",
      "Write(.tdc/**)",
      "Bash(bash $HOME/.tdc/hooks/*)"
    ]
  }
}
